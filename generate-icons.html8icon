<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>ICU Icon + Splash Generator</title>
<style>
body{font-family:sans-serif;padding:20px;background:#f0f7f7}
h2{color:#0d4f4f}
button{padding:10px 18px;margin:5px;font-size:14px;background:#0d4f4f;color:white;border:none;border-radius:8px;cursor:pointer}
button:hover{background:#1a6b6b}
.section{background:white;border-radius:12px;padding:16px;margin-bottom:16px}
.preview{display:flex;gap:10px;flex-wrap:wrap;margin-top:10px}
.preview img{border-radius:8px;border:1px solid #ddd}
small{color:#666;display:block;margin-top:6px}
</style>
</head>
<body>
<h2>🏥 สร้าง Icon + Splash Screen สำหรับ PWA</h2>

<div class="section">
  <h3>1) Icon (สำหรับ Home Screen)</h3>
  <small>กดทั้ง 2 ปุ่ม แล้วเอาไฟล์ไปไว้ในโฟลเดอร์ <code>icons/</code></small>
  <div>
    <button onclick="genIcon(192)">⬇️ Download icon-192.png</button>
    <button onclick="genIcon(512)">⬇️ Download icon-512.png</button>
  </div>
  <div class="preview" id="icon-preview"></div>
</div>

<div class="section">
  <h3>2) Splash Screen (สำหรับหน้าจอเปิดแอพ — iOS ต้องการแบบนี้)</h3>
  <small>กดปุ่มทั้งหมดทีละปุ่ม (8 ขนาด) ทุกไฟล์เอาไปไว้ใน <code>icons/</code> เหมือนกัน ชื่อไฟล์ห้ามเปลี่ยน</small>
  <div>
    <button onclick="genSplash(1170,2532)">iPhone 12/13/14</button>
    <button onclick="genSplash(1284,2778)">iPhone 14 Plus/Pro Max</button>
    <button onclick="genSplash(1125,2436)">iPhone X/11 Pro</button>
    <button onclick="genSplash(1242,2688)">iPhone 11 Pro Max</button>
    <button onclick="genSplash(828,1792)">iPhone 11/XR</button>
    <button onclick="genSplash(750,1334)">iPhone SE/8</button>
    <button onclick="genSplash(1668,2388)">iPad Air/Pro 11"</button>
    <button onclick="genSplash(2048,2732)">iPad Pro 12.9"</button>
  </div>
  <div style="margin-top:10px">
    <button onclick="genAllSplash()" style="background:#2a9d8f">⚡ Download ทั้งหมดทีเดียว (8 ไฟล์)</button>
  </div>
  <div class="preview" id="splash-preview"></div>
</div>

<canvas id="c" style="display:none"></canvas>

<script>
function drawIcon(ctx, size){
  var grad = ctx.createLinearGradient(0,0,size,size);
  grad.addColorStop(0,'#0d4f4f');
  grad.addColorStop(1,'#2a9d8f');
  ctx.fillStyle = grad;
  ctx.beginPath();
  ctx.roundRect(0,0,size,size,size*0.2);
  ctx.fill();
  ctx.font = (size*0.55)+'px serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText('🏥', size/2, size/2);
}

function genIcon(size){
  var c = document.getElementById('c');
  c.width = size; c.height = size;
  var ctx = c.getContext('2d');
  drawIcon(ctx, size);
  download(c, 'icon-'+size+'.png');
  preview('icon-preview', c, 80);
}

function drawSplash(ctx, w, h){
  var grad = ctx.createLinearGradient(0,0,w,h);
  grad.addColorStop(0,'#0d4f4f');
  grad.addColorStop(1,'#1a6b6b');
  ctx.fillStyle = grad;
  ctx.fillRect(0,0,w,h);

  var iconSize = Math.min(w,h) * 0.22;
  var cx = w/2, cy = h/2 - iconSize*0.3;

  ctx.fillStyle = 'rgba(255,255,255,0.15)';
  ctx.beginPath();
  ctx.roundRect(cx-iconSize/2, cy-iconSize/2, iconSize, iconSize, iconSize*0.22);
  ctx.fill();
  ctx.strokeStyle = 'rgba(255,255,255,0.3)';
  ctx.lineWidth = Math.max(2, iconSize*0.02);
  ctx.stroke();

  ctx.font = (iconSize*0.55)+'px serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText('🏥', cx, cy);

  ctx.fillStyle = 'white';
  ctx.font = 'bold '+(w*0.055)+'px Arial';
  ctx.fillText('ICU Trauma', w/2, cy + iconSize*0.9);

  ctx.fillStyle = 'rgba(168,221,216,0.9)';
  ctx.font = (w*0.03)+'px Arial';
  ctx.fillText('โรงพยาบาลยะลา', w/2, cy + iconSize*0.9 + w*0.06);
}

function genSplash(w, h){
  var c = document.getElementById('c');
  c.width = w; c.height = h;
  var ctx = c.getContext('2d');
  drawSplash(ctx, w, h);
  download(c, 'splash-'+w+'x'+h+'.png');
  preview('splash-preview', c, 60);
}

function genAllSplash(){
  var sizes = [[1170,2532],[1284,2778],[1125,2436],[1242,2688],[828,1792],[750,1334],[1668,2388],[2048,2732]];
  var i = 0;
  function next(){
    if(i >= sizes.length) return;
    genSplash(sizes[i][0], sizes[i][1]);
    i++;
    setTimeout(next, 400);
  }
  next();
}

function download(canvas, filename){
  var a = document.createElement('a');
  a.download = filename;
  a.href = canvas.toDataURL('image/png');
  a.click();
}

function preview(containerId, canvas, displayHeight){
  var img = new Image();
  img.src = canvas.toDataURL();
  img.style.height = displayHeight+'px';
  document.getElementById(containerId).appendChild(img);
}
</script>
</body>
</html>
